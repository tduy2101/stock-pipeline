VNSTOCK_API_KEY=

# structured_daily DAG — universe cổ phiếu (Airflow ingest_structured):
# watchlist50 = 50 mã cố định VN30+đa ngành (mặc định DAG). listing = full HOSE/HNX từ listing.
STRUCTURED_DAG_UNIVERSE=watchlist50
# Chỉ khi STRUCTURED_DAG_UNIVERSE=listing: cap N mã đầu alphabet HOSE/HNX (không phải watchlist).
# STRUCTURED_MAX_TICKERS=50

# dbt / warehouse (host). Airflow container overrides via docker/airflow/.env.airflow:
# PG_HOST=host.docker.internal  PG_PORT=55432
# DATABASE_URL=postgresql://stock:stock@host.docker.internal:55432/stock_pipeline

# Crawl www.hnx.vn: neu Jupyter/Python bao SSLCertVerificationError, thu (chi dev):
# HNX_SSL_VERIFY=0
# BCTC backfill (ghi de config.hnx_max_list_pages=10): HNX_CRAWL_MAX_LIST_PAGES=500
# DAG weekly: khong set — dung mac dinh 10 trang trong SemiStructuredIngestionConfig

# (Tuy chon / du phong) Khong dung cho crawl AJAX HNX hien tai — chi neu sau nay them nguon URL tuy chinh
# HNX_DISCLOSURE_API_URL=
